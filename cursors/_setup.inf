[Version]
signature="$CHICAGO$"
Material Design Dark Cursors Pack By DenizhaN

[DefaultInstall]
CopyFiles = Scheme.Cur
AddReg    = Scheme.Reg,Wreg

[DestinationDirs]
Scheme.Cur = 10,"%CUR_DIR%"

[Scheme.Reg]
HKCU,"Control Panel\Cursors\Schemes","%SCHEME_NAME%",,"%10%\%CUR_DIR%\%work%,%10%\%CUR_DIR%\%pointer%,%10%\%CUR_DIR%\%Cross%,%10%\%CUR_DIR%\%help%,%10%\%CUR_DIR%\%Text%,%10%\%CUR_DIR%\%Unavailiable%,%10%\%CUR_DIR%\%handwriting%,%10%\%CUR_DIR%\%account%,%10%\%CUR_DIR%\%place%,%10%\%CUR_DIR%\%move%,%10%\%CUR_DIR%\%Dgn2%,%10%\%CUR_DIR%\%Vert%,%10%\%CUR_DIR%\%Dgn1%,%10%\%CUR_DIR%\%Horz%,%10%\%CUR_DIR%\%alternate%,%10%\%CUR_DIR%\%busy%,%10%\%CUR_DIR%\%link%"

[Wreg]
HKCU,"Control Panel\Cursors",,0x00020000,"%SCHEME_NAME%"
HKCU,"Control Panel\Cursors",AppStarting,0x00020000,"%10%\%CUR_DIR%\%work%"
HKCU,"Control Panel\Cursors",Arrow,0x00020000,"%10%\%CUR_DIR%\%pointer%"
HKCU,"Control Panel\Cursors",Crosshair,0x00020000,"%10%\%CUR_DIR%\%cross%"
HKCU,"Control Panel\Cursors",Hand,0x00020000,"%10%\%CUR_DIR%\%link%"
HKCU,"Control Panel\Cursors",Help,0x00020000,"%10%\%CUR_DIR%\%help%"
HKCU,"Control Panel\Cursors",IBeam,0x00020000,"%10%\%CUR_DIR%\%text%"
HKCU,"Control Panel\Cursors",No,0x00020000,"%10%\%CUR_DIR%\%unavailiable%"
HKCU,"Control Panel\Cursors",NWPen,0x00020000,"%10%\%CUR_DIR%\%handwriting%"
HKCU,"Control Panel\Cursors",Person,0x00020000,"%10%\%CUR_DIR%\%account%"
HKCU,"Control Panel\Cursors",Pin,0x00020000,"%10%\%CUR_DIR%\%place%"
HKCU,"Control Panel\Cursors",SizeAll,0x00020000,"%10%\%CUR_DIR%\%move%"
HKCU,"Control Panel\Cursors",SizeNESW,0x00020000,"%10%\%CUR_DIR%\%dgn2%"
HKCU,"Control Panel\Cursors",SizeNS,0x00020000,"%10%\%CUR_DIR%\%vert%"
HKCU,"Control Panel\Cursors",SizeNWSE,0x00020000,"%10%\%CUR_DIR%\%dgn1%"
HKCU,"Control Panel\Cursors",SizeWE,0x00020000,"%10%\%CUR_DIR%\%horz%"
HKCU,"Control Panel\Cursors",UpArrow,0x00020000,"%10%\%CUR_DIR%\%alternate%"
HKCU,"Control Panel\Cursors",Wait,0x00020000,"%10%\%CUR_DIR%\%busy%"
HKLM,"SOFTWARE\Microsoft\Windows\CurrentVersion\Runonce\Setup\","",,"rundll32.exe shell32.dll,Control_RunDLL main.cpl @0,1"

[Scheme.Cur]
"work.ani"
"pointer.cur"
"cross.cur"
"link.cur"
"help.cur"
"text.cur"
"unavailiable.cur"
"handwriting.cur"
"account.cur"
"place.cur"
"move.cur"
"dgn2.cur"
"vert.cur"
"dgn1.cur"
"horz.cur"
"alternate.cur"
"busy.ani"

[Strings]
CUR_DIR= "Cursors\MaterialDesignDark"
SCHEME_NAME= "Material Design Dark"
work= "work.ani"
pointer= "pointer.cur"
cross= "cross.cur"
link= "link.cur"
help= "help.cur"
text= "text.cur"
unavailiable= "unavailiable.cur"
handwriting= "handwriting.cur"
account= "account.cur"
place= "place.cur"
move= "move.cur"
dgn2= "dgn2.cur"
vert= "vert.cur"   
dgn1= "dgn1.cur"
horz= "horz.cur"
alternate= "alternate.cur"
busy= "busy.ani"
